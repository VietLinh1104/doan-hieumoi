# =========================================================================
# CONFIGURATION FOR EXPRESSJS BACKEND SERVICE
# =========================================================================

# Server environment configuration
PORT=5000
NODE_ENV=development

# MongoDB Database configuration
MONGODB_URI=mongodb://127.0.0.1:27017/auto_parts_db

# Security & Authentication (JSON Web Tokens)
# Please change this to a strong random key in production
JWT_SECRET=supersecretkey_for_jwt_auth_12345
